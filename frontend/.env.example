# Leave empty for same-origin /api (Railway unified + Vite proxy)
# VITE_API_URL=http://localhost:3001

# Public site origin for OG/canonical/JSON-LD/sitemap (no trailing slash).
# Default at build: https://raktasetu-production.up.railway.app
# At domain cutover set to https://raktasetu.in (see docs/ops/domain-cutover.md)
# VITE_SITE_ORIGIN=https://raktasetu-production.up.railway.app

# Google Identity Services client ID (must match backend GOOGLE_CLIENT_ID)
# VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# VITE_APP_VERSION=1.1.0
