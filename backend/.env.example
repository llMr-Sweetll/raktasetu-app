PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
# Local/CI disposable DB only — never point TEST_DATABASE_URL at production Neon.
# TEST_DATABASE_URL=postgresql://cgh@127.0.0.1:5432/raktasetu_test
# FIXTURE_PASSWORD=test-fixture-pass-12
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=30m
# Comma-separated browser origins for CORS / Socket.io when frontend is NOT same-origin.
# Unified Railway deploy is same-origin — localhost Vite is the usual extra origin.
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3001
# Set to false to disable serving frontend/dist from Express
# SERVE_FRONTEND=true

# Google Sign-In (optional — omit to hide Google button / return 503 on /api/auth/google)
GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=   # not required for GIS ID-token verify

# Web Push VAPID (optional — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@raktasetu.org
