PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d
# Comma-separated browser origins for CORS / Socket.io when frontend is NOT same-origin.
# Unified Railway deploy is same-origin — localhost Vite is the usual extra origin.
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3001
# Set to false to disable serving frontend/dist from Express
# SERVE_FRONTEND=true
