{
  "name": "raktasetu-backend",
  "version": "1.0.0",
  "description": "RaktaSetu Blood Donation Platform API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --test tests/*.test.js",
    "test:security": "node --test tests/startup.security.test.js tests/security-controls.test.js tests/donation.transaction.test.js tests/access.matrix.test.js tests/push.ownership.test.js tests/socket.authorization.test.js",
    "test:rls": "node --test tests/rls.integration.test.js",
    "test:bounded-performance": "node scripts/bounded-performance.js",
    "db:migrate": "node scripts/migrate.js",
    "db:test:migrate": "NODE_ENV=test node scripts/migrate.js",
    "db:test:fixtures": "NODE_ENV=test node scripts/seed-fixtures.js",
    "retention": "node src/jobs/retention.js",
    "lint": "eslint src tests scripts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "google-auth-library": "^10.9.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  }
}
